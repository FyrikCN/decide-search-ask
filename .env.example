# OpenAI-compatible API (OpenAI / proxy / self-hosted gateway)
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1

# Small model: decide whether to search
DECISION_MODEL=gpt-4o-mini
# Larger model: filter search results and answer
ANSWER_MODEL=gpt-5.5-pro

# Exa search (used only when the decision model says SEARCH)
EXA_API_KEY=your_exa_api_key

PORT=4000
